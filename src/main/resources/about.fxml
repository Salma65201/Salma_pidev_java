<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="tn.esprit.controllers.AboutController"
      prefHeight="720.0" prefWidth="1280.0"
      style="-fx-background-color: #0d1b3e;">

    <fx:include source="/Navbar.fxml"/>

    <VBox spacing="16" VBox.vgrow="ALWAYS" style="-fx-padding: 28 40 32 40;">
        <Label text="Blog &amp; actualités"
               style="-fx-text-fill: white; -fx-font-size: 26px; -fx-font-weight: bold;"/>
        <Label fx:id="subtitleLabel"
               text="Articles publiés (table blog en base de données)"
               style="-fx-text-fill: #94a3b8; -fx-font-size: 13px;"/>

        <TableView fx:id="blogTable" VBox.vgrow="ALWAYS" style="-fx-background-color: #1e2d4a;">
            <columns>
                <TableColumn fx:id="idCol" text="ID" prefWidth="50"/>
                <TableColumn fx:id="titleCol" text="Titre" prefWidth="220"/>
                <TableColumn fx:id="categoryCol" text="Catégorie" prefWidth="120"/>
                <TableColumn fx:id="dateCol" text="Date" prefWidth="160"/>
                <TableColumn fx:id="commentsCol" text="Commentaires" prefWidth="100"/>
                <TableColumn fx:id="contentCol" text="Contenu (extrait)" prefWidth="400"/>
            </columns>
        </TableView>

        <Label fx:id="messageLabel" text="" style="-fx-font-size: 13px;"/>
    </VBox>
</VBox>
