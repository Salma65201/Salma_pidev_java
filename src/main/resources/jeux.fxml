<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="tn.esprit.controllers.JeuxController"
      prefHeight="720.0" prefWidth="1280.0"
      style="-fx-background-color: #0d1b3e;">

    <fx:include source="/Navbar.fxml"/>

    <VBox spacing="18" VBox.vgrow="ALWAYS" style="-fx-padding: 28 40 32 40;">
        <HBox alignment="CENTER_LEFT" spacing="16">
            <VBox spacing="4">
                <Label text="BIBLIOTHÈQUE"
                       style="-fx-text-fill: #7c3aed; -fx-font-size: 12px; -fx-font-weight: bold; -fx-letter-spacing: 2px;"/>
                <Label text="Jeux"
                       style="-fx-text-fill: white; -fx-font-size: 28px; -fx-font-weight: bold;"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="+ Nouveau jeu" onAction="#handleNewJeu"
                    style="-fx-background-color: #7c3aed; -fx-text-fill: white; -fx-font-size: 14px;
                           -fx-pref-height: 42px; -fx-pref-width: 160px; -fx-cursor: hand; -fx-background-radius: 8;"/>
        </HBox>

        <HBox spacing="14">
            <VBox alignment="CENTER" prefWidth="180" prefHeight="88"
                  style="-fx-background-color: #1e2d4a; -fx-background-radius: 10;">
                <Label fx:id="totalJeuxLabel" text="0"
                       style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #a78bfa;"/>
                <Label text="JEUX EN BASE"
                       style="-fx-text-fill: #94a3b8; -fx-font-size: 11px;"/>
            </VBox>
        </HBox>

        <TableView fx:id="jeuxTable" VBox.vgrow="ALWAYS"
                   style="-fx-background-color: #1e2d4a;">
            <columns>
                <TableColumn fx:id="idCol" text="ID" prefWidth="50"/>
                <TableColumn fx:id="nomCol" text="Nom" prefWidth="180"/>
                <TableColumn fx:id="genreCol" text="Genre" prefWidth="120"/>
                <TableColumn fx:id="plateformeCol" text="Plateforme" prefWidth="120"/>
                <TableColumn fx:id="statutCol" text="Statut" prefWidth="100"/>
                <TableColumn fx:id="descCol" text="Description" prefWidth="320"/>
                <TableColumn fx:id="actionsCol" text="Actions" prefWidth="160"/>
            </columns>
        </TableView>

        <Label fx:id="messageLabel" text="" style="-fx-font-size: 13px;"/>
    </VBox>
</VBox>
